# Database (Neon Postgres — auto-provisioned on Vercel)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=       # Random secret for session signing (generate with: openssl rand -base64 32)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — Email verification (optional, verification disabled when absent)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Asakiri <noreply@yourdomain.com>

# Patreon OAuth (optional — enables creator tier gating)
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=

# Vercel Blob (auto-provisioned on Vercel)
BLOB_READ_WRITE_TOKEN=

# AI Exercise Generation (optional)
GEMINI_API_KEY=
